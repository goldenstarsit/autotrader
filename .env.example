# =====================================================
# AutoTrader Configuration
# =====================================================

# Application
NODE_ENV=development
APP_NAME=AutoTrader
APP_PORT=3000
APP_HOST=0.0.0.0
TIMEZONE=Asia/Karachi

# Logging
LOG_LEVEL=info

# Exchange
EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Trading
DEFAULT_QUOTE_ASSET=USDT
MAX_OPEN_TRADES=1
DRY_RUN=true

# Database
DATABASE_PATH=./data/database/autotrader.db

# WebSocket
WS_RECONNECT_INTERVAL=5000

# Backups
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
